<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}
        {%- if title != null and env.projectNode.title != null %} - {% endif -%}
        {%- if env.projectNode.title -%}{{ env.projectNode.title }}{%- endif -%}
    </title>
    {%~ block head %}
    {%~ endblock %}
</head>
<body>
<!-- content start -->
{%~ block body %}
{%~ endblock %}
<!-- content end -->
</body>
</html>
